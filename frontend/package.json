{
	"name": "notebird-frontend",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"build": "esbuild src/composer.js --bundle --minify --outfile=../internal/templates/html/static/dist/app.js",
